# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Strava
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:8080/callback

# Strava webhook — choose any secret string, then use it when registering
# your webhook subscription with Strava's API.
STRAVA_WEBHOOK_VERIFY_TOKEN=choose_a_secret_string

# Webhook / OAuth server
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Optional
LOG_LEVEL=INFO
